# Cloudflare Pages security headers for getwhoof.pages.dev.
#
# CSP keeps 'unsafe-inline' for script-src because index.html ships inline
# <script type="module"> blocks and an inline font onload; tightening that to
# nonces is a follow-up that needs a browser to verify. The policy still blocks
# framing, plugins, off-origin connections, and base-uri hijacking. Web
# Bluetooth is left at the browser default (allowed for same-origin).
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# Service worker: never cache so updates propagate immediately on reload.
/sw.js
  Cache-Control: no-cache
  Service-Worker-Allowed: /
